CreateFeature("Anti-TwistedSquirmGarb", "Anti struggle automatic when grabbed", function()
    local function tap(dir) game.ReplicatedStorage.Events.TwistedSquirmGrab:FireServer(unpack({"Struggle", dir})) end
    local ui = game.Players.LocalPlayer.PlayerGui:FindFirstChild("TwistedSquirmEscapeUI")
    if ui then
        ui.Changed:Connect(function()
            if ui.Enabled then
                task.spawn(function()
                    while ui.Enabled do tap("left") task.wait(0.05) tap("right") task.wait(0.05) end
                end)
            end
        end)
    end
end)

CreateFeature("egg hunt esp", "Show egg locations in lobby", function()
    local Workspace = game:GetService("Workspace")
    local CoreGui = game:GetService("CoreGui")
    if CoreGui:FindFirstChild("SproutEggESP") then CoreGui.SproutEggESP:Destroy() end
    local folder = Instance.new("Folder", CoreGui)
    folder.Name = "SproutEggESP"
    for _, v in pairs(Workspace:GetDescendants()) do
        if v.Name:lower():find("egg") and (v:IsA("BasePart") or v:IsA("Model")) then
            local isPickable = v:FindFirstChildWhichIsA("TouchTransmitter", true) or v:FindFirstChildWhichIsA("ClickDetector", true)
            if isPickable and not v:IsDescendantOf(game.Players) then
                local hl = Instance.new("Highlight", folder)
                hl.FillColor = Color3.fromRGB(255, 105, 180)
                hl.Adornee = v
                local bbg = Instance.new("BillboardGui", folder)
                bbg.Size, bbg.AlwaysOnTop, bbg.Adornee = UDim2.new(0,100,0,50), true, v
                local l = Instance.new("TextLabel", bbg)
                l.Size, l.BackgroundTransparency, l.Text, l.TextColor3, l.TextSize = UDim2.new(1,0,1,0), 1, "EGG HERE! 🍓", Color3.new(1,1,1), 14
            end
        end
    end
end)

